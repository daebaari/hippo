#!/usr/bin/env bash
# Resolve symlinks so --project points to the real repo, not the symlink dir.
SOURCE="${BASH_SOURCE[0]}"
while [ -L "$SOURCE" ]; do
  DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
  SOURCE="$(readlink "$SOURCE")"
  [[ "$SOURCE" != /* ]] && SOURCE="$DIR/$SOURCE"
done
SCRIPT_DIR="$(cd -P "$(dirname "$SOURCE")" && pwd)"
exec uv run --project "$SCRIPT_DIR/.." --quiet python -m hippo.cli.archive "$@"
