#!/usr/bin/env python3
"""Daemon entry point. Started by launchd; serves until killed."""
from __future__ import annotations

import asyncio
import os
import sys
from pathlib import Path

# Allow running this script directly without `uv run`
_HERE = Path(__file__).resolve().parent
sys.path.insert(0, str(_HERE.parent / "src"))

from hippo.daemon.server import DaemonServer

DEFAULT_SOCKET = Path.home() / ".claude" / "memory-daemon.sock"


def main() -> int:
    sock_path = Path(os.environ.get("HIPPO_DAEMON_SOCKET", DEFAULT_SOCKET))
    server = DaemonServer.load()
    asyncio.run(server.serve(sock_path))
    return 0


if __name__ == "__main__":
    raise SystemExit(main())
